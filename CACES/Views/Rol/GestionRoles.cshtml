@model List<CACES.DAL.DTOs.Roles.GestionRolDTO>

@{
    ViewData["Title"] = "Gestión de Roles";
    var roles = ViewBag.Roles as List<CACES.DAL.Entidades.Roles.AspNetRole>;
}

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="card-header border-0 py-4"
             style="background:#163B73;">

            <h2 class="text-white fw-bold mb-1">
                <i class="bi bi-person-gear me-2"></i>
                Gestión de Roles
            </h2>

            <p class="text-white-50 mb-0">
                Administre los permisos y roles de los usuarios registrados.
            </p>

        </div>

        <div class="card-body p-4">

            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success rounded-3 shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Mensaje"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                </div>
            }

            <div class="table-responsive border rounded-4 shadow-sm overflow-hidden">

                <table class="table table-hover align-middle mb-0">

                    <thead style="background:#163B73;color:white;">

                        <tr>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Rol Actual</th>
                            <th style="width:320px;">Cambiar Rol</th>
                            <th style="width:180px;">Acciones</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var usuario in Model)
                        {
                            <tr>

                                <td class="fw-semibold">
                                    @usuario.NombreCompleto
                                </td>

                                <td>
                                    @usuario.CorreoElectronico
                                </td>

                                <td>

                                    <span class="badge rounded-pill px-3 py-2"
                                          style="background:#DDF7F8;color:#0B6F73;">

                                        @usuario.NombreRol

                                    </span>

                                </td>

                                <td>

                                    <form asp-action="CambiarRol"
                                          asp-controller="Rol"
                                          method="post"
                                          class="d-flex gap-2">

                                        <input type="hidden"
                                               name="userId"
                                               value="@usuario.UserId" />

                                        <select name="roleId"
                                                class="form-select form-select-sm rounded-3 shadow-sm">

                                            @foreach (var rol in roles)
                                            {
                                                <option value="@rol.Id"
                                                        selected="@(rol.Id == usuario.RoleId)">
                                                    @rol.Name
                                                </option>
                                            }

                                        </select>

                                        <button type="submit"
                                                class="btn btn-sm text-white"
                                                style="background:#20C4D8;border:none;">

                                            <i class="bi bi-check-lg"></i>

                                        </button>

                                    </form>

                                </td>

                                <td>

                                    @if (usuario.NombreRol == "Medico")
                                    {
                                        <form asp-action="EliminarMedico"
                                              asp-controller="Rol"
                                              method="post">

                                            <input type="hidden"
                                                   name="userId"
                                                   value="@usuario.UserId" />

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm rounded-3"
                                                    onclick="return confirm('¿Desea eliminar este médico?');">

                                                <i class="bi bi-person-x-fill me-1"></i>

                                                Eliminar

                                            </button>

                                        </form>
                                    }

                                    @if (usuario.NombreRol == "Administrador")
                                    {
                                        <form asp-action="EliminarAdministrador"
                                              asp-controller="Rol"
                                              method="post">

                                            <input type="hidden"
                                                   name="userId"
                                                   value="@usuario.UserId" />

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm rounded-3"
                                                    onclick="return confirm('¿Desea eliminar este administrador?');">

                                                <i class="bi bi-person-x-fill me-1"></i>

                                                Eliminar

                                            </button>

                                        </form>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>