@{
    ViewData["Title"] = "Mis Cotizaciones";
}

<div class="container py-5">

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <!-- ENCABEZADO -->
        <div class="card-header border-0 p-4"
             style="background:#163B73;">

            <div class="d-flex flex-column flex-md-row
                justify-content-between
                align-items-md-center gap-3">

                <div>

                    <h3 class="mb-1 fw-bold text-white">

                        <i class="bi bi-file-earmark-medical-fill me-2"></i>
                        Mis Cotizaciones

                    </h3>

                    <p class="mb-0 text-white-50">

                        Consulte el estado y los montos de sus solicitudes de cotización.

                    </p>

                </div>

                <a asp-controller="Cotizacion"
                   asp-action="SolicitarCotizacion"
                   class="btn text-white px-4 py-2 rounded-3 fw-semibold"
                   style="background:#20C4D8;border:none;">

                    <i class="bi bi-plus-lg me-2"></i>
                    Solicitar Cotización

                </a>

            </div>

        </div>

        <!-- CONTENIDO -->
        <div class="card-body p-4">

            <div id="alertaMisCotizaciones"
                 class="alert alert-danger border-0 rounded-3 shadow-sm d-none">

                <i class="bi bi-exclamation-triangle-fill me-2"></i>

                <span id="textoAlertaMisCotizaciones">
                    No fue posible cargar sus cotizaciones.
                </span>

            </div>

            <div id="sinMisCotizaciones"
                 class="alert alert-info border-0 rounded-3 shadow-sm text-center py-4 d-none">

                <i class="bi bi-file-earmark-x fs-2 d-block mb-2"></i>

                Todavía no tiene solicitudes de cotización registradas.

            </div>

            <div id="contenedorMisCotizaciones"
                 class="table-responsive border rounded-4 shadow-sm overflow-hidden">

                <table id="tbMisCotizaciones"
                       class="table table-hover align-middle mb-0">

                    <thead>

                        <tr>

                            <th>Fecha</th>

                            <th>Procedimiento</th>

                            <th>Médico</th>

                            <th class="text-end">
                                Total
                            </th>

                            <th class="text-center">
                                Estado
                            </th>

                            <th class="text-center"
                                style="min-width:220px;">

                                Acciones

                            </th>

                        </tr>

                    </thead>

                    <tbody>
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<style>

    #tbMisCotizaciones thead th {
        background: #ffffff;
        color: #111827;
        border-bottom: 1px solid #dee2e6;
        padding: 14px 12px;
        font-size: .9rem;
        font-weight: 600;
        white-space: nowrap;
    }

    #tbMisCotizaciones tbody td {
        padding: 14px 12px;
        vertical-align: middle;
        border-bottom: 1px solid #e5e7eb;
    }

    #tbMisCotizaciones tbody tr:last-child td {
        border-bottom: none;
    }

    #tbMisCotizaciones tbody tr:hover {
        background: #f8fafc;
    }

    #tbMisCotizaciones .badge {
        font-weight: 500;
    }

</style>

@section Scripts {

    <script src="~/js/Cotizaciones.js"
            asp-append-version="true">
    </script>

}