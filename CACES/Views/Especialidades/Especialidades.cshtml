@using CACES.BLL.DTOs.Especialidad
@model IEnumerable<mostrarEspecialidadDTO>


@{
    ViewData["Title"] = "Especialidades";
}
<section class="container py-5">

    <div class="col-12 col-lg-10 mx-auto mb-4 text-center">
        <div class="cotizar-banner">
            <h4>¿Desea cotizar algun procedimiento médico?</h4>
            <a href="formularios/Cotizacion.html" class="btn btn-cotizar mt-3">Cotizar</a>
        </div>
    </div>
    <div class="top-action">
        <a class="btn btn-primary" asp-action="RegistroEspecialidad" asp-controller="Especialidad">
            + Registrar Especialidad
        </a>
    </div>
    <section class="mt-4">
        <h1 class="section-title mb-5">Nuestras Especialidades</h1>
        <div class="row g-4" id="contenedorEspecialidades">

                
            <!-- Endoscopia y Colonoscopia -->
            <div class="col-12 col-md-6 col-lg-4">
                <article class="card h-100 border-0 shadow-sm specialty-card">
                    <div class="card-body d-flex flex-column">
                        <div class="mb-3">
                            <i class="bi bi-eye-fill info-icon"></i>
                        </div>
                        <h4 class="card-title mb-2">Endoscopia y Colonoscopia</h4>
                        <p class="text-muted mb-3 flex-grow-1">
                            Visualización y tratamiento de vías digestivas superiores e inferiores mediante técnicas minimamente invasivas.
                        </p>
                        <a href="formularios/Endoscopia.html" class="btn btn-info w-100 mt-auto">Reservar cita</a>
                    </div>
                </article>
            </div>

           
        </div>
    </section>
</section>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
    <script src="~/js/Especialidad.js" asp-append-version="true"></script>
}

