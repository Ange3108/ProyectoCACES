@model CACES.DAL.Entidades.HistorialMedico

@{
    ViewData["Title"] = "Editar Historial Médico";
}

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-header border-0 rounded-top-4 py-4"
             style="background:#163B73;">

            <h2 class="text-white fw-bold mb-1">
                <i class="bi bi-pencil-square me-2"></i>
                Editar Historial Médico
            </h2>

            <p class="text-white-50 mb-0">
                Actualice la información clínica del paciente
            </p>

        </div>

        <div class="card-body p-4">

            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success rounded-3 shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Mensaje"]
                </div>
            }

            <form asp-action="Editar" method="post">

                <input type="hidden" asp-for="IdHistorial" />

                <div class="row g-4">

                    <div class="col-md-6">
                        <label asp-for="TipoSangre"
                               class="form-label fw-semibold"
                               style="color:#163B73;">
                        </label>

                        <input asp-for="TipoSangre"
                               class="form-control rounded-3 shadow-sm" />

                        <span asp-validation-for="TipoSangre"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Alergias"
                               class="form-label fw-semibold"
                               style="color:#163B73;">
                        </label>

                        <input asp-for="Alergias"
                               class="form-control rounded-3 shadow-sm" />

                        <span asp-validation-for="Alergias"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EnfermedadesCronicas"
                               class="form-label fw-semibold"
                               style="color:#163B73;">
                        </label>

                        <input asp-for="EnfermedadesCronicas"
                               class="form-control rounded-3 shadow-sm" />

                        <span asp-validation-for="EnfermedadesCronicas"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Medicamentos"
                               class="form-label fw-semibold"
                               style="color:#163B73;">
                        </label>

                        <input asp-for="Medicamentos"
                               class="form-control rounded-3 shadow-sm" />

                        <span asp-validation-for="Medicamentos"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Antecedentes"
                               class="form-label fw-semibold"
                               style="color:#163B73;">
                        </label>

                        <textarea asp-for="Antecedentes"
                                  rows="3"
                                  class="form-control rounded-3 shadow-sm"></textarea>

                        <span asp-validation-for="Antecedentes"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Detalles"
                               class="form-label fw-semibold"
                               style="color:#163B73;">
                        </label>

                        <textarea asp-for="Detalles"
                                  rows="5"
                                  class="form-control rounded-3 shadow-sm"></textarea>

                        <span asp-validation-for="Detalles"
                              class="text-danger small"></span>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex gap-3">

                    <button type="submit"
                            class="btn text-white px-4 py-2"
                            style="background:#163B73;border:none;">

                        <i class="bi bi-check-lg me-2"></i>

                        Guardar Cambios

                    </button>

                    <a asp-action="Detalle"
                       asp-route-id="@Model.IdHistorial"
                       class="btn text-white px-4 py-2"
                       style="background:#20C4D8;border:none;">

                        <i class="bi bi-arrow-left me-2"></i>

                        Cancelar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}