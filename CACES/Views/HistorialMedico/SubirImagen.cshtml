@{
    ViewData["Title"] = "Subir Imagen Médica";
}

<div class="container mt-5">

    <div class="card shadow">
        <div class="card-header text-white" style="background-color:#27418C;">
            <h3 class="mb-0">Subir Imagen al Historial Médico</h3>
        </div>

        <div class="card-body">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            <form asp-action="SubirImagen"
                  asp-controller="HistorialMedico"
                  method="post"
                  enctype="multipart/form-data">

                <input type="hidden"
                       name="idHistorial"
                       value="@ViewBag.IdHistorial" />

                <div class="mb-3">
                    <label class="form-label fw-bold">
                        Imagen médica
                    </label>

                    <input type="file"
                           name="archivo"
                           class="form-control"
                           accept=".jpg,.jpeg,.png,.pdf,.dcm" />
                </div>

                <div class="mb-3">
                    <small class="text-muted">
                        Puede subir radiografías, resonancias, tomografías o documentos PDF.
                    </small>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit"
                            yclass="btn text-white"
                            stle="background-color:#27418C;">
                        Subir Archivo
                    </button>

                    <a asp-action="Detalle"
                       asp-controller="HistorialMedico"
                       asp-route-id="@ViewBag.IdHistorial"
                       class="btn btn-secondary">
                        Cancelar
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>