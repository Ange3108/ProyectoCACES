@{
    ViewData["Title"] = "Subir Imagen Médica";
}

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-header border-0 rounded-top-4 py-4"
             style="background:#163B73;">

            <h2 class="text-white fw-bold mb-1">
                <i class="bi bi-cloud-arrow-up-fill me-2"></i>
                Subir Imagen Médica
            </h2>

            <p class="text-white-50 mb-0">
                Agregue radiografías, resonancias, tomografías o documentos al historial clínico
            </p>

        </div>

        <div class="card-body p-4">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                </div>
            }

            <form asp-action="SubirImagen"
                  asp-controller="HistorialMedico"
                  method="post"
                  enctype="multipart/form-data">

                <input type="hidden"
                       name="idHistorial"
                       value="@ViewBag.IdHistorial" />

                <div class="border rounded-4 p-4 shadow-sm mb-4"
                     style="background:#F8FBFD;">

                    <label class="form-label fw-bold mb-2"
                           style="color:#163B73;">
                        Imagen médica o archivo clínico
                    </label>

                    <input type="file"
                           name="archivo"
                           class="form-control rounded-3 shadow-sm"
                           accept=".jpg,.jpeg,.png,.pdf,.dcm" />

                    <small class="text-muted d-block mt-3">
                        <i class="bi bi-info-circle-fill me-1"
                           style="color:#20C4D8;"></i>
                        Puede subir archivos JPG, PNG, PDF o DCM.
                    </small>

                </div>

                <div class="alert border-0 rounded-4"
                     style="background:#EAF9FC;color:#163B73;">

                    <i class="bi bi-shield-check me-2"></i>
                    El archivo será asociado directamente al historial médico seleccionado.

                </div>

                <div class="d-flex gap-3 mt-4">

                    <button type="submit"
                            class="btn text-white px-4 py-2"
                            style="background:#163B73;border:none;">

                        <i class="bi bi-upload me-2"></i>
                        Subir Archivo

                    </button>

                    <a asp-action="Detalle"
                       asp-controller="HistorialMedico"
                       asp-route-id="@ViewBag.IdHistorial"
                       class="btn text-white px-4 py-2"
                       style="background:#20C4D8;border:none;">

                        <i class="bi bi-arrow-left me-2"></i>
                        Cancelar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>