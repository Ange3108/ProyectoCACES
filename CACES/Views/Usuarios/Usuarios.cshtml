@using CACES.BLL.DTOs.Usuario
@model IEnumerable<MostrarUsuarioDTO>

@{
    ViewData["Title"] = "Registros de Usuarios";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Listado de Usuarios</h1>
        <a class="btn btn-primary" asp-action="RegistroUsuario" asp-controller="Usuario">
            + Registrar Usuario
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <p class="text-muted mb-3">Gestión de usuarios del sistema</p>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Nombre completo</th>
                            <th>Correo Electrónico</th>
                            <th>DUI</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th style="width: 180px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var usuario in Model)
                            {
                                <tr>
                                    <td>@usuario.Nombres @usuario.PrimerApellido @usuario.SegundoApellido</td>
                                    <td>@usuario.CorreoElectronico</td>
                                    <td>@usuario.DUI</td>
                                    <td>@usuario.Telefono</td>
                                    <td>
                                        @if (usuario.Estado)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <a class="btn btn-sm btn-warning"
                                           asp-action="ActualizarUsuario"
                                           asp-controller="Usuario"
                                           asp-route-id="@usuario.idUsuario">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <form asp-action="EliminarUsuario"
                                              asp-controller="Usuario"
                                              asp-route-id="@usuario.idUsuario"
                                              method="post"
                                              class="d-inline">
                                            <button type="submit"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('¿Seguro que deseas eliminar este usuario?');">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    No hay usuarios registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>