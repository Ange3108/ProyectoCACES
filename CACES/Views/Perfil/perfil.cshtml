@using CACES.BLL.DTOs.Perfil
@model PerfilUsuarioDTO

@{
    ViewData["Title"] = "Perfil del Usuario";
}
  
<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="d-flex align-items-center justify-content-between mb-4">
                <h1 class="h2 fw-bold mb-0" style="color:#0B2E59;">Mi Perfil</h1>

                <span class="badge rounded-pill px-3 py-2 @(Model.Estado ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") fw-semibold">
                    <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>
                    @(Model.Estado ? "Cuenta Activa" : "Cuenta Inactiva")
                </span>
            </div>

            <div class="card border-0 shadow overflow-hidden">

                <div style="height:100px;background:#0B2E59;"></div>

                <div class="card-body p-4 p-md-5 position-relative" style="background:#F8FBFD;">

                    <div class="text-center text-md-start d-md-flex align-items-end gap-4 mb-5" style="margin-top:-75px;">

                        <img id="imgAvatar" src="" alt="Avatar" class="rounded-circle shadow-sm mx-auto mx-md-0" style="width:110px; height:110px; object-fit:cover; border:4px solid #fff; display:none;" />
                        <div id="avatar-iniciales" class="rounded-circle shadow-sm align-items-center justify-content-center text-white fw-bold mx-auto mx-md-0" style="width:110px; height:110px; background:#0B2E59; border:4px solid #fff; font-size:2.25rem; font-family:'Manrope',sans-serif; display:none;"></div>

                        <div class="mt-3 mt-md-0 pt-md-4">
                            <h2 class="fw-bold h3 mb-1" style="color:#1F2937;">@Model.Nombres @Model.PrimerApellido @Model.SegundoApellido</h2>
                            <p class="text-muted mb-0"><i class="bi bi-envelope me-1"></i> @Model.CorreoElectronico</p>
                        </div>
                    </div>

                    <section class="mb-5">
                        <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-4">
                            <h3 class="h5 fw-bold mb-0" style="color:#0B2E59;"><i class="bi bi-person-fill me-2" style="color:#1AA6A6;"></i> Información Personal</h3>
                            <a class="btn btn-sm fw-semibold px-3 text-white" style="background:#1AA6A6;border:none;" href="/Perfil/ActualizarPerfilObt?id=@Model.IdUsuario">
                                <i class="bi bi-pencil-square me-1"></i> Editar
                            </a>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="p-3 rounded-3" style="background:#fff;border-left:4px solid #1AA6A6;">
                                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Nombre completo</label>
                                    <p class="mb-0 fw-medium" style="color:#1F2937;">@Model.Nombres</p>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="p-3 rounded-3" style="background:#fff;border-left:4px solid #1AA6A6;">
                                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Apellidos</label>
                                    <p class="mb-0 fw-medium" style="color:#1F2937;">@Model.PrimerApellido @Model.SegundoApellido</p>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="p-3 rounded-3" style="background:#fff;border-left:4px solid #1AA6A6;">
                                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Documento Único de Identidad (DUI)</label>
                                    <p class="mb-0 fw-medium" style="color:#1F2937;">@Model.DUI</p>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="p-3 rounded-3" style="background:#fff;border-left:4px solid #1AA6A6;">
                                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Teléfono de Contacto</label>
                                    <p class="mb-0 fw-medium" style="color:#1F2937;">@Model.Telefono</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="mb-3">
                        <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-4">
                            <h3 class="h5 fw-bold mb-0" style="color:#0B2E59;"><i class="bi bi-heart-pulse-fill me-2" style="color:#1AA6A6;"></i> Ficha Médica General</h3>
                            <a id="btnHistorial" class="btn btn-sm text-white fw-semibold px-3" style="background:#0B2E59;" href="#">
                                <i class="bi bi-file-earmark-medical me-1"></i> Ver Historial Completo
                            </a>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <div class="p-3 rounded-3 h-100" style="background:#fff;">
                                    <label class="form-label text-muted small fw-bold text-uppercase mb-1"><i class="bi bi-droplet-fill me-1" style="color:#2E8B57;"></i> Tipo de sangre</label>
                                    <p class="mb-0 fw-bold h5" style="color:#0B2E59;">@Model.TipoSangre</p>
                                </div>
                            </div>
                            <div class="col-12 col-md-8">
                                <div class="p-3 rounded-3 h-100" style="background:#fff;">
                                    <label class="form-label text-muted small fw-bold text-uppercase mb-1"><i class="bi bi-exclamation-triangle-fill me-1" style="color:#1AA6A6;"></i> Alergias Conocidas</label>
                                    <p class="mb-0 text-muted small">@Model.Alergias</p>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="p-3 rounded-3 h-100" style="background:#fff;">
                                    <label class="form-label text-muted small fw-bold text-uppercase mb-1"><i class="bi bi-clipboard2-pulse me-1" style="color:#0B2E59;"></i> Patologías o Enfermedades Previas</label>
                                    <p class="mb-0 text-muted small">@Model.EnfermedadesCronicas</p>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="p-3 rounded-3 h-100" style="background:#fff;">
                                    <label class="form-label text-muted small fw-bold text-uppercase mb-1"><i class="bi bi-capsule me-1" style="color:#1AA6A6;"></i> Últimos Medicamentos Recetados</label>
                                    <p class="mb-0 fw-semibold small" style="color:#1F2937;">@Model.MedicamentosActuales</p>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </div>

        </div>
    </div>
</main>

@section Scripts {
    <script>
        // Inyectamos el modelo de C# directamente en una variable de JS
        const datosPerfil = @Html.Raw(Json.Serialize(Model));

        function resolverFoto(foto) {
            if (!foto || typeof foto !== 'string' || foto.trim() === '') return null;
            const fotoLimpia = foto.trim();
            if (fotoLimpia.startsWith('http')) return fotoLimpia;
            return '/img/' + fotoLimpia;
        }

        $(function () {
            console.log("Datos del perfil recibidos:", datosPerfil);
            // 1. Resolver el Historial con JS
            $('#btnHistorial').attr('href', `/HistorialMedico/Detalle?id=${datosPerfil.idHistorial}`);

            // 2. Resolver la Foto dinámicamente (Soporta local y la nube a futuro)
            const fotoUrl = resolverFoto(datosPerfil.foto);
            if (fotoUrl) {
                $('#imgAvatar').attr('src', fotoUrl).show();
            } else {
                const iniciales = `${datosPerfil.nombres.charAt(0)}${datosPerfil.primerApellido.charAt(0)}`.toUpperCase();
                $('#avatar-iniciales').text(iniciales).css('display', 'flex');
            }
        });
    </script>
}