@using CACES.BLL.DTOs.Perfil
@model ActualizarPerfilDTO

@{
    ViewData["Title"] = "Actualizar Perfil del Usuario";
}

<main class="container py-5">

    <h1 class="fw-bold mb-4" style="color:#0B2E59;">
        Actualizar Perfil del Usuario
    </h1>


        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger"
             role="alert"></div>

        <form asp-action="ActualizarPerfil"
              asp-controller="Perfil"
              method="post"
              enctype="multipart/form-data"
              class="card border-0 shadow p-4"
              style="background:#F8FBFD;">

        <input type="hidden" asp-for="IdUsuario" />
        <input type="hidden" asp-for="Foto" />

        <section class="text-center mb-5">

            <h2 class="mt-3 fw-bold" style="color:#0B2E59;">
                @Model.Nombres @Model.PrimerApellido
            </h2>

            <p class="text-muted">
                Paciente
            </p>

        </section>

        <section class="mb-5">

            <h3 class="mb-3 fw-bold" style="color:#0B2E59;">
                <i class="bi bi-person-fill"
                   style="color:#1AA6A6;"></i>
                Información Personal
            </h3>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="Nombres" class="form-label fw-semibold">Nombre</label>
                    <input type="text"
                           asp-for="Nombres"
                           class="form-control"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="Nombres" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="PrimerApellido" class="form-label fw-semibold">Primer Apellido</label>
                    <input type="text"
                           asp-for="PrimerApellido"
                           class="form-control"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="PrimerApellido" class="text-danger"></span>
                </div>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="SegundoApellido" class="form-label fw-semibold">Segundo Apellido</label>
                    <input type="text"
                           asp-for="SegundoApellido"
                           class="form-control"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="SegundoApellido" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Telefono" class="form-label fw-semibold">Teléfono</label>
                    <input type="text"
                           asp-for="Telefono"
                           class="form-control"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="Telefono" class="text-danger"></span>
                </div>

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="CorreoElectronico" class="form-label fw-semibold">Correo Electrónico</label>
                    <input type="email"
                           asp-for="CorreoElectronico"
                           class="form-control"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="DUI" class="form-label fw-semibold">Documento Único de Identidad (DUI)</label>
                    <input type="text"
                           asp-for="DUI"
                           class="form-control"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="DUI" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Direccion" class="form-label fw-semibold">Dirección</label>
                    <input type="text"
                           asp-for="Direccion"
                           class="form-control"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="Direccion" class="text-danger"></span>
                </div>
                

            </div>

        </section>

        <section class="mb-5">

            <h3 class="mb-3 fw-bold" style="color:#0B2E59;">
                <i class="bi bi-lock-fill"
                   style="color:#1AA6A6;"></i>
                Seguridad
            </h3>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="NuevaContraseña" class="form-label fw-semibold">Nueva Contraseña</label>
                    <input type="password"
                           asp-for="NuevaContraseña"
                           class="form-control"
                           placeholder="Dejar en blanco para mantener actual"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="NuevaContraseña" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ConfirmarContraseña" class="form-label fw-semibold">Confirmar Nueva Contraseña</label>
                    <input type="password"
                           asp-for="ConfirmarContraseña"
                           class="form-control"
                           placeholder="Dejar en blanco para mantener actual"
                           style="border-color:#D7E3EC;">
                    <span asp-validation-for="ConfirmarContraseña" class="text-danger"></span>
                </div>
            </div>

            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       asp-for="Activar2FA">
                <label class="form-check-label" asp-for="Activar2FA">
                    Activar autenticación en dos pasos (2FA)
                </label>
            </div>

        </section>

        <div class="row g-2">

            <div class="col-md-6">
                <button type="submit"
                        class="btn w-100 fw-semibold text-white"
                        style="background:#1AA6A6;">
                    <i class="bi bi-save"></i>
                    Guardar cambios
                </button>
            </div>

            <div class="col-md-6">
                <a asp-action="VerPerfil"
                   asp-controller="Perfil"
                   class="btn w-100 fw-semibold text-white"
                   style="background:#6B7280;">
                    Cancelar
                </a>
            </div>

        </div>

    </form>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}