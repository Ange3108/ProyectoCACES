@using CACES.BLL.DTOs.Procedimientos
@model RegistrarProcedimientosDto

@{
    ViewData["Title"] = "Agendar Cirugía";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-dark text-white py-3">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-calendar-plus-fill fs-4 me-2"></i>
                        <h5 class="mb-0 fw-bold">Agendar Procedimiento Quirúrgico</h5>
                    </div>
                </div>

                <div class="card-body p-4">
                    <p class="text-muted small mb-4">
                        Complete los siguientes campos para registrar y asignar un espacio en el quirófano al paciente.
                    </p>

                    <form asp-action="Registrar" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small p-2" role="alert"></div>

                        <input type="hidden" asp-for="Id_Paciente" />

                        <div class="mb-3">
                            <label asp-for="Id_Procedimiento" class="form-label fw-semibold text-secondary">
                                <i class="bi bi-activity me-1"></i> Tipo de Procedimiento
                            </label>
                            <select asp-for="Id_Procedimiento" class="form-select border-2"
                                    asp-items="@(new SelectList(ViewBag.Procedimientos, "Id_Procedimiento", "Nombre"))">
                                <option value="" selected disabled>-- Seleccione la cirugía  --</option>
                            </select>
                            <span asp-validation-for="Id_Procedimiento" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Id_Medico" class="form-label fw-semibold text-secondary">
                                <i class="bi bi-person-md me-1"></i> Médico Especialista Asignado
                            </label>
                            <select asp-for="Id_Medico" class="form-select border-2">
                                <option value="" selected disabled>-- Seleccione el especialista activo --</option>
                                @if (ViewBag.Medicos != null)
                                {
                                    foreach (var medico in ViewBag.Medicos)
                                    {
                                        <option value="@medico.IdMedico">
                                            Dr. @medico.Usuario?.Nombres @medico.Usuario?.PrimerApellido
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="Id_Medico" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="FechaProgramada" class="form-label fw-semibold text-secondary">
                                <i class="bi bi-clock me-1"></i> Fecha y Hora de la Intervención
                            </label>
                            <input asp-for="FechaProgramada" type="datetime-local" class="form-control border-2" />
                            <span asp-validation-for="FechaProgramada" class="text-danger small"></span>
                        </div>

                        <hr class="text-muted my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="ObtenerProcedimientos" class="btn btn-light border fw-semibold px-4">
                                Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary fw-semibold px-4 shadow-sm">
                                <i class="bi bi-check-circle-fill me-1"></i> Agendar Cirugía
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
