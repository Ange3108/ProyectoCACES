@using CACES.BLL.DTOs.Procedimientos
@model IEnumerable<MostrarProcedimientosDTO>

@{
    ViewData["Title"] = "Procedimientos Quirúrgicos - CACES";
    int idPaciente = ViewBag.IdPaciente ?? Model?.FirstOrDefault()?.Id_Paciente ?? 0;
}

<style>
    .procedure-header-bar {
        background: linear-gradient(135deg, #27418C 0%, #1a2d6b 100%);
        border-radius: 16px;
        padding: 2rem 2.5rem;
        color: white;
        margin-bottom: 2rem;
    }

        .procedure-header-bar h4 {
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.02em;
        }

        .procedure-header-bar p {
            opacity: 0.75;
            font-size: 0.9rem;
            margin: 0.25rem 0 0;
        }

    .btn-agendar {
        background: white;
        color: #27418C;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        padding: 0.55rem 1.4rem;
        font-size: 0.9rem;
        white-space: nowrap;
        transition: background 0.2s, box-shadow 0.2s;
    }

        .btn-agendar:hover {
            background: #e8eef8;
            color: #1a2d6b;
            box-shadow: 0 4px 14px rgba(39,65,140,0.25);
        }

    .surgery-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        transition: transform 0.2s, box-shadow 0.2s;
        overflow: hidden;
        border-top: 4px solid #72CEF2 !important;
    }

        .surgery-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 28px rgba(39,65,140,0.13);
        }

        .surgery-card .card-body {
            padding: 1.5rem;
        }

    .surgery-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1a2d6b;
        margin: 0;
        line-height: 1.3;
    }

    .badge-pendiente {
        background-color: #fff3cd;
        color: #856404;
        border: 1px solid #ffc107;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.3rem 0.65rem;
        border-radius: 20px;
        white-space: nowrap;
    }

    .badge-realizada {
        background-color: #f0f0f0;
        color: #6c757d;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.3rem 0.65rem;
        border-radius: 20px;
        white-space: nowrap;
    }

    .surgery-meta {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin: 0.9rem 0;
    }

    .surgery-meta-item {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: #444;
    }

        .surgery-meta-item i {
            color: #72CEF2;
            flex-shrink: 0;
            margin-top: 0.1rem;
        }

        .surgery-meta-item .label {
            color: #888;
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            display: block;
            line-height: 1;
            margin-bottom: 0.05rem;
        }

    .surgery-description {
        font-size: 0.85rem;
        color: #777;
        line-height: 1.5;
        border-top: 1px solid #f0f0f0;
        padding-top: 0.75rem;
        margin-top: 0.25rem;
    }

    .card-actions {
        display: flex;
        gap: 0.6rem;
        margin-top: 1rem;
    }

    .btn-descargar {
        background-color: #27418C;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.5rem 1rem;
        flex: 1;
        transition: background 0.2s;
        text-align: center;
    }

        .btn-descargar:hover {
            background-color: #1a2d6b;
            color: white;
        }

    .btn-editar {
        background-color: transparent;
        border: 1.5px solid #72CEF2;
        color: #27418C;
        border-radius: 10px;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.5rem 1rem;
        flex: 1;
        transition: background 0.2s;
        text-align: center;
    }

        .btn-editar:hover {
            background-color: #e8f7fd;
            color: #1a2d6b;
        }

    .empty-state {
        background: #f8fafc;
        border-radius: 16px;
        padding: 3.5rem 2rem;
        text-align: center;
        color: #adb5bd;
    }

        .empty-state i {
            font-size: 2.8rem;
            margin-bottom: 1rem;
            display: block;
        }

        .empty-state p {
            font-size: 1rem;
            margin: 0;
        }
</style>

<main class="container py-5">
    <section class="mt-3">

        <div class="procedure-header-bar d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h4><i class="bi bi-scissors me-2" style="opacity:0.75;"></i>Procedimientos Quirúrgicos</h4>
                <p>Próximas cirugías programadas para el paciente</p>
            </div>

            @if (User.IsInRole("Administrador") && idPaciente > 0)
            {
                <a class="btn btn-agendar"
                   asp-controller="Procedimientos"
                   asp-action="Registrar"
                   asp-route-idPaciente="@idPaciente">
                    <i class="bi bi-calendar-plus-fill me-1"></i> Agendar Cirugía
                </a>
            }
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var cirugia in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <article class="card surgery-card h-100">
                            <div class="card-body d-flex flex-column">

        
                                <div class="d-flex justify-content-between align-items-start mb-1 gap-2">
                                    <h5 class="surgery-title">@cirugia.Nombre</h5>
                                    @if (cirugia.Estado)
                                    {
                                        <span class="badge-pendiente">
                                            <i class="bi bi-clock me-1"></i>Pendiente
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-realizada">Finalizada</span>
                                    }
                                </div>

                          
                                <div class="surgery-meta">
                                    @if (User.IsInRole("Medico") || User.IsInRole("Administrador"))
                                    {
                                        <div class="surgery-meta-item">
                                            <i class="bi bi-person-fill"></i>
                                            <div>
                                                <span class="label">Paciente</span>
                                                @cirugia.NombrePaciente
                                            </div>
                                        </div>
                                    }

                                    <div class="surgery-meta-item">
                                        <i class="bi bi-person-badge-fill"></i>
                                        <div>
                                            <span class="label">Médico</span>
                                            @cirugia.NombreMedico
                                        </div>
                                    </div>

                                    <div class="surgery-meta-item">
                                        <i class="bi bi-calendar3"></i>
                                        <div>
                                            <span class="label">Fecha y hora</span>
                                            @cirugia.Fecha.ToString("dd/MM/yyyy") — @cirugia.Fecha.ToString("hh:mm tt")
                                        </div>
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(cirugia.Descripcion))
                                {
                                    <p class="surgery-description">@cirugia.Descripcion</p>
                                }

             
                                <div class="card-actions mt-auto">
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <a class="btn-editar"
                                           asp-controller="Procedimientos"
                                           asp-action="Editar"
                                           asp-route-idPaciente="@cirugia.Id_Paciente"
                                           asp-route-id="@cirugia.Id_Cirugia">
                                            <i class="bi bi-pencil-square me-1"></i> Editar
                                        </a>
                                    }
                                    <a class="btn-descargar"
                                       asp-controller="Procedimientos"
                                       asp-action="DescargarReporteProcedimiento"
                                       asp-route-id="@cirugia.Id_Cirugia">
                                        <i class="bi bi-file-earmark-pdf me-1"></i> Descargar Historial
                                    </a>
                                </div>

                            </div>
                        </article>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state">
                        <i class="bi bi-calendar-x"></i>
                        <p>No hay procedimientos quirúrgicos programados en este momento.</p>
                    </div>
                </div>
            }
        </div>

    </section>
</main>
