@using CACES.BLL.DTOs.Procedimientos
@model IEnumerable<MostrarProcedimientosDTO>

@{
    ViewData["Title"] = "Procedimientos Quirúrgicos - CACES";
    int idPaciente = ViewBag.IdPaciente ?? Model?.FirstOrDefault()?.Id_Paciente ?? 0;
}

<main class="container py-5">
    <section class="mt-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
            <h4 class="section-title mb-0">Próximos procedimientos quirúrgicos del paciente</h4>

            @if (User.IsInRole("Administrador") && idPaciente > 0)
            {
                <a class="btn btn-success shadow-sm px-4 fw-semibold"
                   asp-controller="Procedimientos"
                   asp-action="Registrar"
                   asp-route-idPaciente="@idPaciente">
                    <i class="bi bi-calendar-plus-fill me-1"></i> Agendar Nueva Cirugía
                </a>
            }
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var cirugia in Model)
                {
                    <div class="col-12 col-lg-4">
                        <article class="card procedure-card border-0 shadow-sm h-100">
                            <div class="card-body d-flex flex-column justify-content-between">
                                <div>
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="mb-1">@cirugia.Nombre</h5>

                                        @if (cirugia.Estado)
                                        {
                                            <span class="badge bg-warning text-dark">Pendiente</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Realizada / Cancelada</span>
                                        }
                                    </div>

                                    @if (User.IsInRole("Medico") || User.IsInRole("Administrador"))
                                    {
                                        <p class="text-primary fw-bold mb-2">
                                            <i class="bi bi-person-fill"></i> Paciente: @cirugia.NombrePaciente
                                        </p>
                                    }

                                    <p class="fw-bold mb-2">@cirugia.NombreMedico</p>

                                    <p class="fw-semibold mb-2">
                                        Fecha: @cirugia.Fecha.ToString("dd/MM/yyyy") — @cirugia.Fecha.ToString("hh:mm tt")
                                    </p>

                                    <p class="text-muted mb-2">@cirugia.Descripcion</p>
                                </div>

                                <div class="d-flex justify-content-center mt-3">
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <a class="btn btn-outline-primary w-100"
                                           asp-controller="Procedimientos"
                                           asp-action="Editar"
                                           asp-route-idPaciente="@cirugia.Id_Paciente"
                                           asp-route-id="@cirugia.Id_Cirugia">
                                            <i class="bi bi-pencil-square"></i> Editar Procedimiento
                                        </a>
                                    }
                                    <a class="btn btn-cotizar px-4"
                                       asp-controller="Procedimientos"
                                       asp-action="DescargarReporteProcedimiento"
                                       asp-route-id="@cirugia.Id_Cirugia">
                                        <i class="bi bi-file-earmark-pdf"></i> Descargar Historial Médico
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted fs-5">No tienes procedimientos quirúrgicos programados en este momento.</p>
                </div>
            }
        </div>
    </section>
</main>