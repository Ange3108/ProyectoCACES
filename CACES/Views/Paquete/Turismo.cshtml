@using CACES.BLL.DTOs.Paquete
@model List<PaqueteDTO>
@{
    ViewData["Title"] = "Turismo Médico - CACES";
}

<main class="container py-5">

    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Administrador"))
    {
        <div class="top-action mb-4">
            <a class="btn text-white fw-semibold" style="background-color: #27418C;" asp-action="CrearPaquete" asp-controller="Paquete">+ Registrar Paquete</a>
        </div>
    }

    <section class="mt-4">
        <h1 class="h2 fw-bold mb-5" style="color: #27418C;">Paquetes de Turismo Médico</h1>
        <p class="text-muted mb-4">
            Pacientes extranjeros eligen nuestros paquetes porque combinan atención médica especializada,
            acompañamiento logístico y costos competitivos en un solo plan.
        </p>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var paquete in Model)
                {
                    <div class="col-12 col-lg-4">
                        <article class="card h-100 border-0 shadow-sm overflow-hidden" style="border-top: 4px solid #72CEF2 !important;">
                            <div class="card-body d-flex flex-column justify-content-between p-4">
                                <div>
                                    <h5 class="fw-bold mb-2" style="color: #27418C;">@paquete.Nombre</h5>
                                    <p class="text-muted small mb-3">@paquete.Descripcion</p>
                                    <p class="fw-bold mb-2" style="color: #27418C;">Precio: USD $@paquete.Precio</p>

                                    <span class="badge rounded-pill px-3 py-2 fw-semibold" style="background-color: #72CEF2; color: #27418C;">
                                        <i class="bi bi-clock me-1"></i> Duración: @paquete.Duracion
                                    </span>
                                </div>

                                <div class="mt-4">
                                    <div class="d-flex gap-2">
                                        <a href="https://wa.me" class="btn text-white fw-semibold w-100 py-2" style="background-color: #27418C;" target="_blank" rel="noopener noreferrer">
                                            <i class="bi bi-whatsapp me-2"></i>Reservar
                                        </a>

                                        @* BOTÓN DE EDITAR: Exclusivo para administradores *@
                                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Administrador"))
                                        {
                                            <a class="btn btn-outline-warning fw-semibold px-3"
                                               asp-action="ActualizarPaquete"
                                               asp-controller="Paquete"
                                               asp-route-id="@paquete.IdPaquete"
                                               title="Editar paquete">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                        }
                                    </div>
                                </div>

                            </div>
                        </article>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5 bg-light rounded-3">
                    <i class="bi bi-archive text-muted" style="font-size: 2.5rem;"></i>
                    <p class="text-muted mt-2 mb-0">No hay paquetes disponibles en este momento.</p>
                </div>
            }
        </div>
    </section>
</main>