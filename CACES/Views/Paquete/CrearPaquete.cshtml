@using CACES.BLL.DTOs.Paquete
@model PaqueteDTO
@{
    ViewData["Title"] = "Registrar Paquete - CACES";
}

<main class="container py-5">
    <section class="form-shell">
        <div class="top-action mb-3">
            <!-- Redirección dinámica usando tag helpers hacia tu acción del listado -->
            <a class="btn btn-add" asp-action="ObtenerPaquetes" asp-controller="Paquete">
                Volver al listado
            </a>
        </div>
        
        <div class="card form-card shadow-sm">
            <div class="card-body p-4 p-md-5">
                <h1 class="section-title mb-3">Registrar Paquete de Turismo Médico</h1>
                <p class="text-muted mb-4">Crea paquetes para el módulo de turismo médico.</p>
                
                <!-- Muestra errores generales de lógica de negocio del servidor -->
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

                <form asp-action="CrearPaquete" asp-controller="Paquete" method="post">
                    <div class="row g-3">
                        
                        <!-- Nombre del Paquete -->
                        <div class="col-12 col-md-6">
                            <label asp-for="Nombre" class="form-label">Nombre del paquete</label>
                            <input asp-for="Nombre" type="text" class="form-control" placeholder="Ej. Evaluación Integral" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <!-- Precio -->
                        <div class="col-12 col-md-3">
                            <label asp-for="Precio" class="form-label">Precio</label>
                            <input asp-for="Precio" type="text" class="form-control" placeholder="USD 480" />
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>

                        <!-- Duración -->
                        <div class="col-12 col-md-3">
                            <label asp-for="Duracion" class="form-label">Duración</label>
                            <input asp-for="Duracion" type="text" class="form-control" placeholder="3 días" />
                            <span asp-validation-for="Duracion" class="text-danger small"></span>
                        </div>

                        <!-- Descripción -->
                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Incluye consulta, exámenes, traslado, etc."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                    </div>

                    <!-- Botones de Acción -->
                    <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 mt-4">
                        <button type="reset" class="btn btn-outline-secondary">Limpiar</button>
                        <button type="submit" class="btn btn-add">Guardar paquete</button>
                    </div>
                </form>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <!-- Activa la lectura de las etiquetas DataAnnotations de tu DTO en el navegador -->
    <partial name="_ValidationScriptsPartial" />
}