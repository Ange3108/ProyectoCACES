@{
    ViewData["Title"] = "Registrar Cita";
}

<div class="container py-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header text-white p-4" style="background-color:#27418C;">
            <h3 class="mb-1">Registrar Cita Médica</h3>
            <p class="mb-0">
                Las citas en CACES se orientan a procedimientos médicos, cirugías, anestesia e internamiento.
            </p>
        </div>

        <div class="card-body p-4">

            <form id="formRegistrarCita">

                <div class="mb-3">
                    <label for="IdEspecialidad" class="form-label fw-semibold">Especialidad</label>
                    <select id="IdEspecialidad" name="IdEspecialidad" class="form-select">
                        <option value="">Seleccione una especialidad</option>
                    </select>
                    <span class="text-danger" data-valmsg-for="IdEspecialidad"></span>
                </div>

                <div class="mb-3">
                    <label for="IdMedico" class="form-label fw-semibold">Médico</label>
                    <select id="IdMedico" name="IdMedico" class="form-select">
                        <option value="">Seleccione un médico</option>
                    </select>
                    <span class="text-danger" data-valmsg-for="IdMedico"></span>
                </div>

                <div class="mb-3">
                    <label for="FechaCita" class="form-label fw-semibold">Fecha</label>
                    <input id="FechaCita" name="FechaCita" type="date" class="form-control" />
                    <span class="text-danger" data-valmsg-for="FechaCita"></span>
                </div>

                <div class="mb-3">
                    <label for="Hora" class="form-label fw-semibold">Hora</label>
                    <input id="Hora" name="Hora" type="time" class="form-control" />
                    <span class="text-danger" data-valmsg-for="Hora"></span>
                </div>

                <div class="mb-3">
                    <label for="Motivo" class="form-label fw-semibold">Motivo</label>
                    <textarea id="Motivo"
                              name="Motivo"
                              class="form-control"
                              rows="3"
                              placeholder="Ejemplo: valoración para cirugía, anestesia o internamiento"></textarea>
                    <span class="text-danger" data-valmsg-for="Motivo"></span>
                </div>

                <div class="alert alert-info">
                    CACES no agenda citas internas para laboratorio o radiología. Estos servicios se gestionan mediante convenios externos.
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn text-white" style="background-color:#27418C;">
                        Registrar Cita
                    </button>

                    <a asp-controller="Cita"
                       asp-action="MisCitas"
                       class="btn btn-secondary">
                        Cancelar
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Cita/RegistrarCita.js"></script>
}