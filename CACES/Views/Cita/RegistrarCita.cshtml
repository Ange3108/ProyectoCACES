@{
    ViewData["Title"] = "Registrar Cita";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header banner-header p-4">

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                <div>
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-calendar-plus me-2"></i>
                        Registrar Nueva Cita
                    </h3>

                    <p class="mb-0 opacity-75">
                        Complete la información para solicitar una nueva cita médica.
                    </p>
                </div>

            </div>

        </div>

        <div class="card-body p-4">

            <form id="formRegistrarCita">

                <div class="row g-4">

                    <div class="col-md-6">

                        <label class="form-label fw-semibold">
                            Especialidad
                        </label>

                        <select id="idEspecialidad"
                                class="form-select"
                                required>

                            <option value="">
                                Seleccione una especialidad
                            </option>

                        </select>

                    </div>

                    <div class="col-md-6">

                        <label class="form-label fw-semibold">
                            Médico
                        </label>

                        <select id="idMedico"
                                class="form-select"
                                required>

                            <option value="">
                                Seleccione un médico
                            </option>

                        </select>

                    </div>

                    <div class="col-md-6">

                        <label class="form-label fw-semibold">
                            Horario
                        </label>

                        <select id="idHorario"
                                class="form-select"
                                required>

                            <option value="">
                                Seleccione un horario
                            </option>

                        </select>

                    </div>

                    <div class="col-md-3">

                        <label class="form-label fw-semibold">
                            Fecha
                        </label>

                        <input type="date"
                               id="fechaCita"
                               class="form-control"
                               required />

                    </div>

                    <div class="col-md-3">

                        <label class="form-label fw-semibold">
                            Hora
                        </label>

                        <input type="time"
                               id="hora"
                               class="form-control"
                               readonly />

                    </div>

                    <div class="col-12">

                        <label class="form-label fw-semibold">
                            Motivo de la consulta
                        </label>

                        <textarea id="motivo"
                                  class="form-control"
                                  rows="4"
                                  maxlength="100"
                                  placeholder="Describa brevemente el motivo de la cita..."
                                  required></textarea>

                        <div class="form-text">
                            Máximo 100 caracteres.
                        </div>

                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2 flex-wrap">

                    <a asp-controller="Cita"
                       asp-action="MisCitas"
                       class="btn btn-secondary">

                        <i class="bi bi-arrow-left me-1"></i>
                        Volver

                    </a>

                    <button type="submit"
                            class="btn btn-primary">

                        <i class="bi bi-check-circle me-1"></i>
                        Guardar Cita

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/citas.js" asp-append-version="true"></script>
}