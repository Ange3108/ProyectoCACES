@model CACES.BLL.DTOs.Cita.MostrarCitaDTO

@{
    ViewData["Title"] = "Ticket de Cita";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden mx-auto"
         style="max-width: 760px;">

        <div class="card-header banner-header p-4">

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                <div>
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-receipt me-2"></i>
                        Ticket de Cita Médica
                    </h3>

                    <p class="mb-0 opacity-75">
                        Comprobante oficial de la cita registrada en CACES.
                    </p>
                </div>

                <span class="badge bg-light text-dark px-3 py-2">
                    N.º @Model.IdCita.ToString("D6")
                </span>

            </div>

        </div>

        <div class="card-body p-4 p-md-5">

            <div class="ticket-summary mb-4">

                <div class="row g-3">

                    <div class="col-md-6">
                        <div class="ticket-item">
                            <span class="ticket-label">
                                <i class="bi bi-person me-2"></i>Paciente
                            </span>

                            <span class="ticket-value">
                                @Model.NombrePaciente
                            </span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="ticket-item">
                            <span class="ticket-label">
                                <i class="bi bi-person-badge me-2"></i>Médico
                            </span>

                            <span class="ticket-value">
                                @Model.NombreMedico
                            </span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="ticket-item">
                            <span class="ticket-label">
                                <i class="bi bi-heart-pulse me-2"></i>Especialidad
                            </span>

                            <span class="ticket-value">
                                @Model.NombreEspecialidad
                            </span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="ticket-item">
                            <span class="ticket-label">
                                <i class="bi bi-calendar-event me-2"></i>Fecha
                            </span>

                            <span class="ticket-value">
                                @Model.FechaCita.ToString("dd/MM/yyyy")
                            </span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="ticket-item">
                            <span class="ticket-label">
                                <i class="bi bi-clock me-2"></i>Hora
                            </span>

                            <span class="ticket-value">
                                @Model.Hora.ToString(@"hh\:mm")
                            </span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="ticket-item">
                            <span class="ticket-label">
                                <i class="bi bi-info-circle me-2"></i>Estado
                            </span>

                            <span class="ticket-value">
                                <span class="badge @(Model.Estado == 1 ? "bg-success" : "bg-secondary")">
                                    @Model.EstadoTexto
                                </span>
                            </span>
                        </div>
                    </div>

                </div>


               

            </div>

            <div class="ticket-motivo mb-4">

                <div class="ticket-label mb-2">
                    <i class="bi bi-chat-left-text me-2"></i>
                    Motivo de la cita
                </div>

                <div class="ticket-motivo-text">
                    @Model.Motivo
                </div>

            </div>

            <div class="ticket-note text-center">
                <i class="bi bi-shield-check me-2"></i>
                Presente este comprobante el día de su cita médica.
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4 flex-wrap">

                <button type="button"
                        class="btn btn-secondary"
                        onclick="history.back()">

                    <i class="bi bi-arrow-left me-1"></i>
                    Volver

                </button>
                <a asp-controller="Cita"
                   asp-action="DescargarTicketPdf"
                   asp-route-id="@Model.IdCita"
                   class="btn btn-primary">

                    <i class="bi bi-file-earmark-pdf me-1"></i>
                    Descargar PDF

                </a>

            </div>

        </div>

    </div>

</div>