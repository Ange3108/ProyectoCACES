@{
    ViewData["Title"] = "Calendario de Citas";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var esMedico = User.IsInRole("Medico");

    var urlEventos = esMedico
        ? Url.Action("ObtenerCitasMedico", "Cita")
        : Url.Action("ObtenerMisCitas", "Cita");

    var urlListado = esMedico
        ? Url.Action("CitasMedico", "Cita")
        : Url.Action("MisCitas", "Cita");
}

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet">

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header banner-header p-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-calendar3 me-2"></i>
                        Calendario de Citas
                    </h3>
                    <p class="mb-0 opacity-75">Vista general de sus citas médicas.</p>
                </div>

                <a href="@urlListado" class="btn btn-light fw-semibold">
                    <i class="bi bi-list-check me-1"></i> Ver listado completo de citas
                </a>
            </div>
        </div>

        <div class="card-body p-4">
            <div id="calendario" data-eventos-url="@urlEventos"></div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="~/js/CalendarioCitas.js" asp-append-version="true"></script>
}