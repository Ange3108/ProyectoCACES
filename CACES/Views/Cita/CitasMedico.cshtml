@{
    ViewData["Title"] = "Citas del Médico";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header banner-header p-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                <div>
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-calendar-week me-2"></i>
                        Agenda de Citas Médicas
                    </h3>

                    <p class="mb-0 opacity-75">
                        Visualice y administre las citas asignadas a su agenda médica.
                    </p>
                </div>

                <button type="button"
                        class="btn btn-light fw-semibold"
                        id="btnRecargarCitas">

                    <i class="bi bi-arrow-clockwise me-1"></i>
                    Actualizar

                </button>

            </div>
        </div>

        <div class="card-body p-4">

            <div id="alertaCitasMedico"
                 class="alert alert-danger rounded-3 d-none">
            </div>

            <div id="sinCitasMedico"
                 class="alert alert-info text-center rounded-3 py-4 d-none">

                <i class="bi bi-info-circle fs-2 d-block mb-2 text-muted"></i>

                No existen citas asignadas.

            </div>

            <div id="contenedorTablaCitasMedico"
                 class="table-responsive">

                <table id="tbCitasMedico"
                       class="table table-hover align-middle mb-0"
                       style="width:100%;">

                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Paciente</th>
                            <th>Especialidad</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody></tbody>

                </table>

            </div>

        </div>
    </div>
</div>

<div class="modal fade"
     id="modalReprogramarCita"
     tabindex="-1"
     aria-labelledby="tituloModalReprogramar"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title fw-bold"
                    id="tituloModalReprogramar">

                    <i class="bi bi-calendar-event me-2"></i>
                    Reprogramar cita

                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                </button>

            </div>

            <div class="modal-body">

                <input type="hidden"
                       id="reprogramarIdCita" />

                <div class="mb-3">

                    <label for="reprogramarFecha"
                           class="form-label fw-semibold">

                        Nueva fecha

                    </label>

                    <input type="date"
                           id="reprogramarFecha"
                           class="form-control" />

                </div>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancelar

                </button>

                <button type="button"
                        class="btn btn-primary"
                        id="btnGuardarReprogramacion">

                    Guardar cambios

                </button>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Cita/CitasMedico.js"
            asp-append-version="true">
    </script>
}