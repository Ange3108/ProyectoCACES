@{
    ViewData["Title"] = "Citas del Médico";
}

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="card-header border-0 p-4" style="background:#163B73;">
            <h2 class="text-white fw-bold mb-1">
                <i class="bi bi-calendar-week-fill me-2"></i>
                Agenda de Citas Médicas
            </h2>
            <p class="text-white-50 mb-0">
                Visualice y administre las citas asignadas a su agenda médica.
            </p>
        </div>

        <div class="card-body p-4">

            <div id="sinCitasMedico" class="alert border-0 rounded-4 shadow-sm" style="background:#EAF9FC;color:#163B73;display:none;">
                <i class="bi bi-info-circle-fill me-2"></i>
                No existen citas asignadas.
            </div>

            <div class="table-responsive border rounded-4 shadow-sm overflow-hidden">
                <table id="tbCitasMedico" class="table table-hover align-middle mb-0">
                    <thead style="background:#163B73;color:white;">
                        <tr>
                            <th>Cita</th>
                            <th>Hora</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th></th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/Cita/CitasMedico.js"></script>
}