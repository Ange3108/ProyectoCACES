@{
    ViewData["Title"] = "Gestión de Citas";
}

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="card-header border-0 p-4" style="background:#163B73;">
            <h2 class="text-white fw-bold mb-1">
                <i class="bi bi-calendar-check-fill me-2"></i>
                Gestión de Citas
            </h2>
            <p class="text-white-50 mb-0">
                Modifique fechas de citas y cancele citas por médico y fecha
            </p>
        </div>

        <div class="card-body p-4">

            <div class="border rounded-4 p-4 shadow-sm mb-5" style="background:#F8FBFD;">

                <h5 class="fw-bold mb-1" style="color:#163B73;">
                    <i class="bi bi-calendar-x-fill me-2" style="color:#20C4D8;"></i>
                    Cancelar citas por médico y fecha
                </h5>

                <p class="text-muted mb-4">
                    Ingrese el ID del médico y la fecha para cancelar las citas activas correspondientes.
                </p>

                <form id="formCancelarPorMedico" class="row g-3 align-items-end">

                    <div class="col-md-5">
                        <label class="form-label fw-semibold" style="color:#163B73;">
                            ID del médico
                        </label>
                        <input type="number" name="idMedico" class="form-control rounded-3 shadow-sm" required />
                    </div>

                    <div class="col-md-5">
                        <label class="form-label fw-semibold" style="color:#163B73;">
                            Fecha de cita
                        </label>
                        <input type="date" name="fechaCita" class="form-control rounded-3 shadow-sm" required />
                    </div>

                    <div class="col-md-2">
                        <button type="submit"
                                class="btn text-white w-100 rounded-3"
                                style="background:#B42318;border:none;">
                            Cancelar
                        </button>
                    </div>

                </form>

            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="fw-bold mb-1" style="color:#163B73;">
                        <i class="bi bi-list-ul me-2" style="color:#20C4D8;"></i>
                        Listado de citas
                    </h5>
                    <p class="text-muted mb-0">
                        Registro general de citas médicas.
                    </p>
                </div>
            </div>

            <div class="table-responsive border rounded-4 shadow-sm overflow-hidden">
                <table id="tbGestionCitas" class="table table-hover align-middle mb-0">
                    <thead style="background:#163B73;color:white;">
                        <tr>
                            <th>ID</th>
                            <th>ID Paciente</th>
                            <th>ID Médico</th>
                            <th>Especialidad</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th style="width:260px;">Modificar Fecha</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/Cita/GestionCitas.js"></script>
}