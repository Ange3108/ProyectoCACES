@{
    ViewData["Title"] = "Gestión de Citas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header banner-header p-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                <div>
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-calendar-check me-2"></i>
                        Gestión de Citas
                    </h3>

                    <p class="mb-0 opacity-75">
                        Administre y consulte las citas médicas registradas.
                    </p>
                </div>

                @if (User.IsInRole("Paciente"))
                {
                    <a asp-controller="Cita"
                       asp-action="RegistrarCita"
                       class="btn btn-light fw-semibold">

                        <i class="bi bi-plus-circle me-1"></i>
                        Nueva Cita

                    </a>
                }

            </div>
        </div>

        <div class="card-body p-4">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0"
                       id="tbGestionCitas"
                       style="width:100%;">

                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Paciente</th>
                            <th>Médico</th>
                            <th>Especialidad</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody></tbody>

                </table>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/citas.js" asp-append-version="true"></script>
}