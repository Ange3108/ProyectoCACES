@{
    ViewData["Title"] = "Mis Citas";
}

<div class="container py-5">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header text-white p-4" style="background-color:#27418C;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="mb-1">Mis Citas Médicas</h3>
                    <p class="mb-0">Consulta las citas registradas en el centro CACES.</p>
                </div>

                <a asp-controller="Cita"
                   asp-action="RegistrarCita"
                   class="btn btn-light fw-semibold">
                    + Registrar Cita
                </a>
            </div>
        </div>

        <div class="card-body p-4">

            <div id="sinCitas" class="alert alert-info" style="display:none;">
                No tienes citas registradas.
            </div>

            <div class="table-responsive">
                <table id="tbMisCitas" class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th>Ticket</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Cita/MisCitas.js"></script>
}