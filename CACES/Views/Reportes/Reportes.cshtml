
@{
	ViewData["Title"] = "Reportes";
}

<div class="container py-5">
    <section class="mt-4">
        <h4 class="section-title mb-5">Reportes del sistema</h4>
        <div class="alighn-items-center ">
            <div class="col-12 col-lg-10">
                <div class="card h-100 mb-4">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title"><i class="bi bi-person"></i> Gestión de Usuarios</h5>
                        <p class="card-text">
                            Administra los usuarios registrados en el sistema, incluyendo pacientes,
                            especialistas y administradores.
                        </p>
                        <a asp-action="Usuarios" asp-controller="Reportes" class="btn btn-info mt-auto">Ver Reporte</a>
                    </div>
                </div>
                <div class="card h-100 mb-4">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title"><i class="bi bi-person"></i> Gestión de Pacientes</h5>
                        <p class="card-text">Administra los pacientes registrados en el sistema, incluyendo su informacion, citas enlazadas y historial médico.</p>
                        <a asp-action="Pacientes" asp-controller="Reportes" class="btn btn-info mt-auto">Ver Reporte</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>