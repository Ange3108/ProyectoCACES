<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CACES</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg custom-navbar">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand brand-block" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon"><img src="~/img/logoCACES.jpg" alt="Logo"></span>
                    <span class="brand-name">CACES</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto nav-center-list">
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Especialidades" asp-action="Especialidades">Especialidades</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Cirugias" asp-action="Procedimientos">Procedimientos Quirúrgicos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Medicos" asp-action="Especialistas">Especialistas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Citas" asp-action="GestionCitas">Citas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Turismo" asp-action="Turismo">Turismo Médico</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="AgendaMedica" asp-action="AgendaMedica">Agenda Médica</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Configuracion" asp-action="Configuracion">Configuración</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Reportes">Reportes</a></li>
                    </ul>

                    <div class="navbar-actions">
                        <div class="lang-switch" aria-label="Seleccionar idioma">
                            <button class="lang-btn" type="button">EN</button>
                            <button class="lang-btn active" type="button">ES</button>
                        </div>
                    </div>
                </div>
                <a class="account-link" asp-area="" asp-controller="Cuenta" asp-action="Perfil" aria-label="Cuenta">
                    <i class="bi bi-person"></i>
                </a>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 py-4" style="background:#72CEF2;">
        <div class="container text-center">
            <p class="mb-1 fw-semibold" style="color:#27418C;">Centro Ambulatorio de Cirugía Escalón</p>
            <p class="mb-0">
                <a asp-area="" asp-controller="Soporte" asp-action="Contacto" class="text-decoration-none fw-bold" style="color:#27418C;">
                    Contacto y soporte
                </a>
            </p>
            <div class="d-flex justify-content-center gap-3 mt-3">
                <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" style="color:#27418C; font-size:1.25rem;">
                    <i class="bi bi-facebook"></i>
                </a>
                <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" style="color:#27418C; font-size:1.25rem;">
                    <i class="bi bi-instagram"></i>
                </a>
                <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X" style="color:#27418C; font-size:1.25rem;">
                    <i class="bi bi-twitter-x"></i>
                </a>
                <a href="https://wa.me/50600000000" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" style="color:#27418C; font-size:1.25rem;">
                    <i class="bi bi-whatsapp"></i>
                </a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
