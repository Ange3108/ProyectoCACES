@{
    ViewData["Title"] = "Especialistas";
}

<section class="container py-5">

    <div class="text-center mb-5">
        <span class="directory-eyebrow" style="color:#1AA6A6;">
            Equipo médico
        </span>

        <h1 class="directory-title" style="color:#0B2E59;">
            Nuestros Especialistas
        </h1>

        <p class="directory-intro" style="color:#6B7280;">
            Conozca el equipo médico disponible para brindarle atención profesional y personalizada.
        </p>
    </div>

    <hr class="directory-rule" style="border-color:#D7E3EC;" />

    <div id="contenedorEspecialistas">
        <div class="text-center py-5">
            <div class="spinner-border"
                 style="color:#1AA6A6;"
                 role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    </div>

</section>

@section Scripts {
    <script src="~/js/Especialistas.js" asp-append-version="true"></script>
}