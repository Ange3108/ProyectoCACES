@{
    ViewData["Title"] = "Especialistas";
}

<section class="container py-5">

    <div class="text-center mb-5">
        <span class="directory-eyebrow">Equipo médico</span>
        <h1 class="directory-title">Nuestros Especialistas</h1>
        <p class="directory-intro">
            Conozca el equipo médico disponible para brindarle atención profesional y personalizada.
        </p>
    </div>

    <hr class="directory-rule" />

    <div id="contenedorEspecialistas">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    </div>

</section>

@section Scripts {
    <script src="~/js/Especialistas.js" asp-append-version="true"></script>
}