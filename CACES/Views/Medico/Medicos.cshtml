@{
    ViewData["Title"] = "Gestión de Médicos";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header banner-header p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-person-badge-fill me-2"></i>Gestión de Médicos
                    </h3>
                    <p class="mb-0 opacity-75">
                        Consulte y administre la información de los médicos del sistema.
                    </p>
                </div>
                <a asp-action="RegistrarEspecialista" asp-controller="Medico" class="btn btn-light fw-semibold">
                    + Registrar Médico
                </a>
            </div>
        </div>

        <div class="card-body p-4">

            <div class="table-responsive">
                <table id="tbMedicos" class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Médico</th>
                            <th>Especialidad</th>
                            <th>Experiencia</th>
                            <th>Certificaciones</th>
                            <th>Estado</th>
                            <th style="width: 120px;">Acciones</th>
                        </tr>
                    </thead>
                </table>
            </div>

        </div>
    </div>
</div>

@* Token requerido para el POST de desactivar sin [ApiController] *@
@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/ListadoMedico.js" asp-append-version="true"></script>
}
    


        
