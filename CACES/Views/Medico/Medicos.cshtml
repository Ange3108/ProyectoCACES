@model List<CACES.DAL.Entidades.Medico>

@{
    ViewData["Title"] = "Listado de Médicos";
}

<div class="container py-5">
    <h1 class="mb-4">Listado de Médicos</h1>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Especialidad</th>
                        <th>Experiencia</th>
                        <th>Certificaciones</th>
                        <th>Estado</th>
                        <th style="width: 120px;">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var medico in Model)
                        {
                            <tr>
                                <td>
                                    @medico.Usuario.Nombres
                                    @medico.Usuario.PrimerApellido
                                    @medico.Usuario.SegundoApellido
                                </td>

                                <td>@medico.IdEspecialidad</td>

                                <td>@medico.Experiencia años</td>

                                <td>@medico.Certificaciones</td>

                                <td>
                                    @if (medico.Usuario.Estado == 1)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex gap-2">
                                        <a class="btn btn-warning btn-sm"
                                           asp-controller="Medico"
                                           asp-action="EditarMedico"
                                           asp-route-id="@medico.IdMedico"
                                           title="Editar médico">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <form asp-action="EliminarMedico"
                                              asp-controller="Medico"
                                              asp-route-id="@medico.IdMedico"
                                              method="post"
                                              onsubmit="return confirm('¿Está seguro de eliminar este médico?');">

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm"
                                                    title="Eliminar médico">
                                                <i class="bi bi-trash"></i>
                                            </button>

                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No hay médicos registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>