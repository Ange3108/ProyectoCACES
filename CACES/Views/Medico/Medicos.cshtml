@model List<CACES.DAL.Entidades.Medico>

@{
    ViewData["Title"] = "Listado de Médicos";
}
<div class="container py-5">
 <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
    <div class="card-header banner-header p-4">
     <div class="d-flex justify-content-between align-items-center">

        <div>
            <h3 class="mb-1 fw-bold">
                <i class="bi bi-person-badge-fill me-2"></i>Gestión de Médicos
            </h3>
            <p class="mb-0 opacity-75">
                Consulte y administre la información de los médicos del sistema.
            </p>
        </div>

        <a asp-action="RegistrarMedico" asp-controller="Medico" class="btn btn-light fw-semibold">
            + Registrar Médico
        </a>

    </div>
    </div>
 

<div class="card-body p-4">

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success rounded-3">
            @TempData["Mensaje"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3">
            @TempData["Error"]
        </div>
    }

            
                <div class="table-responsive">

            <table id="tbMedicos" class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Especialidad</th>
                        <th>Experiencia</th>
                        <th>Certificaciones</th>
                        <th>Estado</th>
                        <th style="width: 120px;">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var medico in Model)
                        {
                            <tr>
                                <td>
                                    @medico.Usuario.Nombres
                                    @medico.Usuario.PrimerApellido
                                    @medico.Usuario.SegundoApellido
                                </td>

                                <td>@medico.IdEspecialidad</td>

                                <td>@medico.Experiencia años</td>

                                <td>@medico.Certificaciones</td>

                                <td>
                                    @if (medico.Usuario.Estado.Equals(true))
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex gap-2">
                                        <a class="btn btn-warning btn-sm"
                                           asp-controller="Medico"
                                           asp-action="EditarMedico"
                                           asp-route-id="@medico.IdMedico"
                                           title="Editar médico">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <form asp-action="EliminarMedico"
                                              asp-controller="Medico"
                                              asp-route-id="@medico.IdMedico"
                                              method="post"
                                              onsubmit="return confirm('¿Está seguro de eliminar este médico?');">

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm"
                                                    title="Eliminar médico">
                                                <i class="bi bi-trash"></i>
                                            </button>

                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No hay médicos registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
        </div>
		</div>
        </div>
    


        
