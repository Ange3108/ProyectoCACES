@model CACES.BLL.DTOs.Medico.EditarMedicoDTO

@{
    ViewData["Title"] = "Editar Médico";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #1f3c88, #4fc3f7);">
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Editar Médico
                    </h3>
                    <p class="mb-0 opacity-75">Actualice la información personal y médica del especialista.</p>
                </div>

                <div class="card-body p-4">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger rounded-3">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        </div>
                    }

                    <form asp-action="EditarMedico"
                          asp-controller="Medico"
                          method="post"
                          enctype="multipart/form-data">

                        <input asp-for="IdMedico" type="hidden" />
                        <input asp-for="IdUsuario" type="hidden" />
                        <input asp-for="Foto" type="hidden" />

                        <h5 class="fw-bold text-primary mb-3">Datos personales</h5>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Nombres" class="form-label fw-semibold">Nombre</label>
                                <input asp-for="Nombres" class="form-control rounded-3" />
                                <span asp-validation-for="Nombres" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="PrimerApellido" class="form-label fw-semibold">Primer apellido</label>
                                <input asp-for="PrimerApellido" class="form-control rounded-3" />
                                <span asp-validation-for="PrimerApellido" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="SegundoApellido" class="form-label fw-semibold">Segundo apellido</label>
                                <input asp-for="SegundoApellido" class="form-control rounded-3" />
                                <span asp-validation-for="SegundoApellido" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Telefono" class="form-label fw-semibold">Teléfono</label>
                                <input asp-for="Telefono" class="form-control rounded-3" />
                                <span asp-validation-for="Telefono" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Estado" class="form-label fw-semibold">Estado</label>
                                <select asp-for="Estado" class="form-select rounded-3">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h5 class="fw-bold text-primary mb-3">Información médica</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="IdEspecialidad" class="form-label fw-semibold">Especialidad</label>
                                <input asp-for="IdEspecialidad" type="number" class="form-control rounded-3" />
                                <span asp-validation-for="IdEspecialidad" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Experiencia" class="form-label fw-semibold">Años de experiencia</label>
                                <input asp-for="Experiencia" type="number" class="form-control rounded-3" />
                                <span asp-validation-for="Experiencia" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Certificaciones" class="form-label fw-semibold">Certificaciones</label>
                            <textarea asp-for="Certificaciones" class="form-control rounded-3" rows="4"></textarea>
                            <span asp-validation-for="Certificaciones" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Foto del médico</label>

                            @if (!string.IsNullOrEmpty(Model.Foto))
                            {
                                <div class="mb-3">
                                    <img src="@Model.Foto"
                                         alt="Foto actual del médico"
                                         class="rounded-circle border shadow-sm"
                                         style="width:120px;height:120px;object-fit:cover;" />
                                </div>
                            }

                            <input type="file"
                                   name="FotoArchivo"
                                   class="form-control rounded-3"
                                   accept="image/*" />

                            <div class="form-text">
                                Seleccione una nueva imagen para reemplazar la foto actual.
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Medicos"
                               asp-controller="Medico"
                               class="btn btn-secondary px-4 rounded-3">
                                <i class="bi bi-arrow-left me-1"></i>Volver
                            </a>

                            <button type="submit" class="btn btn-primary px-4 rounded-3">
                                <i class="bi bi-save me-1"></i>Guardar Cambios
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<h1>PRUEBA MAJO</h1>