@using CACES.BLL.DTOs.Medico
@model RegistrarMedicoDTO

@{
    ViewData["Title"] = "Registrar Especialista";
}

<main class="container py-5">
    <section class="form-shell">
        <div class="top-action mb-3">
            <a class="btn btn-add" asp-controller="Medico" asp-action="Medicos">Volver al listado</a>
        </div>
        <div class="card form-card shadow-sm">
            <div class="card-body p-4 p-md-5">
                <h1 class="section-title mb-3">Registrar Especialista</h1>
                <p class="text-muted mb-4">Agrega un nuevo profesional al equipo médico.</p>

                <form id="formRegistrarMedico"
                      asp-controller="Medico"
                      asp-action="CrearMedico"
                      method="post"
                      enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <h5 class="fw-bold text-primary mb-3">Datos personales</h5>
                    <div class="row g-3">

                        <div class="col-12 col-md-4">
                            <label asp-for="Nombres" class="form-label">Nombre</label>
                            <input asp-for="Nombres" type="text" class="form-control" placeholder="Ej. Ana">
                            <span asp-validation-for="Nombres" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="PrimerApellido" class="form-label">Primer apellido</label>
                            <input asp-for="PrimerApellido" type="text" class="form-control" placeholder="Ej. Morales">
                            <span asp-validation-for="PrimerApellido" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="SegundoApellido" class="form-label">Segundo apellido</label>
                            <input asp-for="SegundoApellido" type="text" class="form-control" placeholder="Ej. García">
                            <span asp-validation-for="SegundoApellido" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="CorreoElectronico" class="form-label">Correo electrónico</label>
                            <input asp-for="CorreoElectronico" type="email" class="form-control" placeholder="correo@ejemplo.com">
                            <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="DUI" class="form-label">DUI</label>
                            <input asp-for="DUI" type="text" class="form-control" placeholder="00000000-0" maxlength="10">
                            <span asp-validation-for="DUI" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" type="tel" class="form-control" placeholder="Ej. 7777-8888">
                            <span asp-validation-for="Telefono" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Nacimiento" class="form-label">Fecha de nacimiento</label>
                            <input asp-for="Nacimiento" type="date" class="form-control">
                            <span asp-validation-for="Nacimiento" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label">Dirección</label>
                            <input asp-for="Direccion" type="text" class="form-control" placeholder="Ej. Col. Escalón, San Salvador">
                            <span asp-validation-for="Direccion" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Password" class="form-label">Contraseña</label>
                            <input asp-for="Password" type="password" class="form-control"
                                   placeholder="Mínimo 8 caracteres, un número y un símbolo">
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label">Foto (opcional)</label>
                            <input type="file" name="FotoArchivo" class="form-control" accept="image/*">
                        </div>

                    </div>

                    <hr class="my-4" />

                    <h5 class="fw-bold text-primary mb-3">Información médica</h5>
                    <div class="row g-3">

                        <div class="col-12 col-md-6">
                            <label asp-for="IdEspecialidad" class="form-label">Especialidad</label>
                            <select asp-for="IdEspecialidad" class="form-select" id="selectEspecialidad">
                                <option value="">Selecciona una especialidad</option>
                            </select>
                            <span asp-validation-for="IdEspecialidad" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Experiencia" class="form-label">Años de experiencia</label>
                            <input asp-for="Experiencia" type="number" class="form-control" min="0" placeholder="Ej. 12">
                            <span asp-validation-for="Experiencia" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Certificaciones" class="form-label">Certificaciones</label>
                            <textarea asp-for="Certificaciones" class="form-control" rows="3"
                                      placeholder="Ej. Doctorado en cirugía, Board Certified Surgeon"></textarea>
                            <span asp-validation-for="Certificaciones" class="text-danger small"></span>
                        </div>

                    </div>

                    <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 mt-4">
                        <button type="reset" class="btn btn-outline-secondary">Limpiar</button>
                        <button type="submit" class="btn btn-add">Guardar especialista</button>
                    </div>

                </form>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
    <script src="~/js/RegistrarMedico.js" asp-append-version="true"></script>
    <script>
        // Carga las especialidades activas en el select al abrir la página
        $.ajax({
        url: '/Especialidad/ObtenerListadoEspecialidades',
        type: 'GET',
        success: function (respuesta) {
        if (!respuesta.dato) return;
        respuesta.dato.forEach(e => {
        if (e.estado) {
        $('#selectEspecialidad').append(
        `<option value="${e.idEspecialidad}">${e.nombre}</option>`
        );
        }
        });
        }
        });
    </script>
}
