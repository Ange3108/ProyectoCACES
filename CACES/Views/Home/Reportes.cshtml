@{
    ViewData["Title"] = "Reportes";
}

<div class="container py-5">
    <section class="mt-4">

        <div class="reports-header mb-5">
            <span class="directory-eyebrow">Panel de administración</span>
            <h2 class="reports-title">Reportes del sistema</h2>
            <p class="reports-intro">Accede y administra cada módulo del sistema desde aquí.</p>
        </div>

        <div class="reports-grid">

            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Usuarios</h5>
                    <p class="report-card-text">Administra los usuarios registrados en el sistema, incluyendo pacientes, especialistas y administradores.</p>
                </div>
                <a asp-action="Usuarios" asp-controller="Usuario" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-person-heart"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Pacientes</h5>
                    <p class="report-card-text">Administra los pacientes registrados, incluyendo su información, citas enlazadas e historial médico.</p>
                </div>
                <a asp-action="Pacientes" asp-controller="Paciente" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-clipboard2-pulse-fill"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Médicos</h5>
                    <p class="report-card-text">Administra los médicos registrados en el sistema, incluyendo su información y citas enlazadas.</p>
                </div>
                <a asp-action="Medicos" asp-controller="Medico" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Roles</h5>
                    <p class="report-card-text">Administra los roles del sistema y controla los permisos asignados a cada usuario.</p>
                </div>
                <a asp-action="GestionRoles" asp-controller="Rol" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            

            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-calendar2-check-fill"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Citas</h5>
                    <p class="report-card-text">Administra las citas registradas en el sistema, revisa su estado e información detallada.</p>
                </div>
                <a asp-action="GestionCitas" asp-controller="Cita" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-hospital-fill"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Especialidades</h5>
                    <p class="report-card-text">Administra las especialidades médicas disponibles en el sistema.</p>
                </div>
                <a asp-action="ListadoEspecialidad" asp-controller="Especialidad" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-briefcase-fill"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Paquetes de Turismo</h5>
                    <p class="report-card-text">Administra los paquetes de turismo médico disponibles en el sistema.</p>
                </div>
                <a asp-action="ObtenerPaquetes" asp-controller="Paquete" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-alarm-fill"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Horarios de doctor</h5>
                    <p class="report-card-text">Administra los horarios disponibles por día para cada médico.</p>
                </div>
                <a asp-action="GestionHorarios" asp-controller="Horario" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi bi-box2-heart"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Iconos del sistema</h5>
                    <p class="report-card-text">Administra los Icono para el sistema</p>
                </div>
                <a asp-action="ListadoIcono" asp-controller="Icono" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="report-card">
                <div class="report-card-icon">
                    <i class="bi-hospital"></i>
                </div>
                <div class="report-card-body">
                    <h5 class="report-card-title">Gestión de Procedimientos quirúrgicos</h5>
                    <p class="report-card-text">Administra los procedimientos quirúrgicos disponibles en el sistema.</p>
                </div>
                <a asp-action="ObtenerProcedimientosQuirur" asp-controller="Procedimientos" class="btn-report">
                    Ver reporte <i class="bi bi-arrow-right"></i>
                </a>
            </div>

        </div>
    </section>
</div>

<style>
    /* ── Encabezado ── */
    .reports-header {
        border-left: 4px solid #72CEF2;
        padding-left: 1.25rem;
    }

    .reports-title {
        font-family: "Playfair Display", serif;
        font-weight: 700;
        color: #12364f;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        margin: 0.3rem 0 0.5rem;
    }

    .reports-intro {
        color: #5b6b79;
        font-size: 1rem;
        margin: 0;
    }

    /* ── Grid de tarjetas ── */
    .reports-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
        gap: 1.5rem;
    }

    /* ── Tarjeta individual ── */
    .report-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid rgba(18, 54, 79, 0.08);
        padding: 1.75rem 1.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        box-shadow: 0 2px 8px rgba(18, 54, 79, 0.05);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .report-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 22px rgba(18, 54, 79, 0.10);
    }

    /* ── Icono ── */
    .report-card-icon {
        width: 3rem;
        height: 3rem;
        border-radius: 12px;
        background: #E9F6FC;
        color: #049DD9;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        flex-shrink: 0;
    }

    /* ── Cuerpo ── */
    .report-card-body {
        flex: 1;
    }

    .report-card-title {
        font-weight: 700;
        color: #12364f;
        font-size: 1rem;
        margin: 0 0 0.4rem;
    }

    .report-card-text {
        color: #5b6b79;
        font-size: 0.9rem;
        line-height: 1.55;
        margin: 0;
    }

    /* ── Botón ── */
    .btn-report {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 700;
        color: #27418C;
        text-decoration: none;
        border-bottom: 1.5px solid #72CEF2;
        padding-bottom: 2px;
        width: fit-content;
        transition: color 0.2s ease, border-color 0.2s ease;
    }

    .btn-report:hover {
        color: #049DD9;
        border-color: #049DD9;
    }

    .btn-report i {
        transition: transform 0.2s ease;
    }

    .btn-report:hover i {
        transform: translateX(3px);
    }

   
</style>
