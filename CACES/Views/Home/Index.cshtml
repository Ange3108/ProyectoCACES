@{
    ViewData["Title"] = "Home Page";
}

<div id="carouselNoticia" class="carousel slide " data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-inner ">
        <div class="carousel-item active">
            <img src="img/noticia1.png" class="d-block w-100" alt="Noticia 1">
        </div>
        <div class="carousel-item">
            <img src="img/noticia1.png" class="d-block w-100" alt="Noticia 2">
        </div>
        <div class="carousel-item">
            <img src="img/noticia1.png" class="d-block w-100" alt="Noticia 3">
        </div>
    </div>
</div>

<section class="mt-5">
    <h3 class="section-title mb-3">Principales especialidades</h3>
    <div class="row g-3">
        <div class="col-12 col-md-6 col-xl-3">
            <a class="card-link-wrap" href="#traumatologia">
                <article class="card info-card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-bandaid-fill info-icon"></i>
                        <h5 class="mt-2 mb-1">Traumatología</h5>
                        <p class="text-muted mb-0">Diagnóstico y tratamiento de lesiones osteomusculares.</p>
                    </div>
                </article>
            </a>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <a class="card-link-wrap" href="#colonoscopia">
                <article class="card info-card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-capsule info-icon"></i>
                        <h5 class="mt-2 mb-1">Colonoscopia</h5>
                        <p class="text-muted mb-0">Procedimiento de diagnóstico gastrointestinal.</p>
                    </div>
                </article>
            </a>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <a class="card-link-wrap" href="#fisioterapia">
                <article class="card info-card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="bi bi-person-raised-hand info-icon"></i>
                        <h5 class="mt-2 mb-1">Fisioterapia</h5>
                        <p class="text-muted mb-0">Rehabilitación y recuperación funcional.</p>
                    </div>
                </article>
            </a>
        </div>
    </div>
</section>

<section class="mt-5">
    <h3 class="section-title mb-3">Especialistas destacados</h3>
    <div class="row g-3">
        <div class="col-12 col-md-6 col-xl-4">
            <a class="card-link-wrap" href="#dra-ana-morales">
                <article class="card info-card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="mb-1">Dra. Ana Morales</h5>
                        <p class="mb-1">Cardióloga</p>
                        <small class="text-muted">12 años de experiencia</small>
                    </div>
                </article>
            </a>
        </div>
        <div class="col-12 col-md-6 col-xl-4">
            <a class="card-link-wrap" href="#dr-luis-andrade">
                <article class="card info-card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="mb-1">Dr. Luis Andrade</h5>
                        <p class="mb-1"></p>
                        <small class="text-muted">Especialista en cirugía artroscópica</small>
                    </div>
                </article>
            </a>
        </div>
        <div class="col-12 col-md-6 col-xl-4">
            <a class="card-link-wrap" href="#dra-sofia-beltran">
                <article class="card info-card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="mb-1">Dra. Sofía Beltrán</h5>
                        <p class="mb-1">Neumóloga</p>
                        <small class="text-muted">Atención respiratoria integral</small>
                    </div>
                </article>
            </a>
        </div>
    </div>
</section>

