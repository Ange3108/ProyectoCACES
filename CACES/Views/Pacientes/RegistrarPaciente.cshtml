@model CACES.BLL.DTOs.Paciente.RegistrarPacienteDTO

@{
    ViewData["Title"] = "Registro de Paciente";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #27418C, #72CEF2);">
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-person-plus-fill me-2"></i>Registro de Paciente
                    </h3>
                    <p class="mb-0 opacity-75">Complete sus datos personales y médicos para crear su cuenta.</p>
                </div>

                <div class="card-body p-4">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger rounded-3">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        </div>
                    }

                    <form asp-action="RegistroPaciente" asp-controller="Paciente" method="post">

                        <h5 class="fw-bold mb-3" style="color:#27418C;">Datos personales</h5>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Usuario.Nombres" class="form-label fw-semibold">Nombre</label>
                                <input asp-for="Usuario.Nombres" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.Nombres" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Usuario.PrimerApellido" class="form-label fw-semibold">Primer apellido</label>
                                <input asp-for="Usuario.PrimerApellido" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.PrimerApellido" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Usuario.SegundoApellido" class="form-label fw-semibold">Segundo apellido</label>
                                <input asp-for="Usuario.SegundoApellido" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.SegundoApellido" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Usuario.CorreoElectronico" class="form-label fw-semibold">Correo electrónico</label>
                                <input asp-for="Usuario.CorreoElectronico" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.CorreoElectronico" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Usuario.DUI" class="form-label fw-semibold">DUI</label>
                                <input asp-for="Usuario.DUI" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.DUI" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Usuario.Telefono" class="form-label fw-semibold">Teléfono</label>
                                <input asp-for="Usuario.Telefono" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.Telefono" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Usuario.Direccion" class="form-label fw-semibold">Dirección</label>
                                <input asp-for="Usuario.Direccion" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.Direccion" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Usuario.Nacimiento" class="form-label fw-semibold">Fecha de nacimiento</label>
                                <input asp-for="Usuario.Nacimiento" type="date" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.Nacimiento" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Usuario.passwordHash" class="form-label fw-semibold">Contraseña</label>
                                <input asp-for="Usuario.passwordHash" type="password" class="form-control rounded-3" />
                                <span asp-validation-for="Usuario.passwordHash" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h5 class="fw-bold mb-3" style="color:#27418C;">Historial médico</h5>

                        <div class="row">
                            <div class="col-md-3 mb-3">
                                <label asp-for="Historial.TipoSangre" class="form-label fw-semibold">Tipo de sangre</label>
                                <input asp-for="Historial.TipoSangre" class="form-control rounded-3" placeholder="Ej: O+" />
                                <span asp-validation-for="Historial.TipoSangre" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Historial.Alergias" class="form-label fw-semibold">Alergias</label>
                                <input asp-for="Historial.Alergias" class="form-control rounded-3" placeholder="Ej: Ninguna" />
                                <span asp-validation-for="Historial.Alergias" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Historial.EnfermedadesCronicas" class="form-label fw-semibold">Enfermedades crónicas</label>
                                <input asp-for="Historial.EnfermedadesCronicas" class="form-control rounded-3" placeholder="Ej: Ninguna" />
                                <span asp-validation-for="Historial.EnfermedadesCronicas" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3 mb-3">
                                <label asp-for="Historial.Antecedentes" class="form-label fw-semibold">Antecedentes</label>
                                <input asp-for="Historial.Antecedentes" class="form-control rounded-3" placeholder="Ej: Ninguno" />
                                <span asp-validation-for="Historial.Antecedentes" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Historial.Detalles" class="form-label fw-semibold">Detalles</label>
                            <textarea asp-for="Historial.Detalles" class="form-control rounded-3" rows="4"></textarea>
                            <span asp-validation-for="Historial.Detalles" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary px-4 rounded-3">
                                <i class="bi bi-arrow-left me-1"></i>Volver
                            </a>

                            <button type="submit" class="btn text-white px-4 rounded-3" style="background:#27418C;">
                                <i class="bi bi-save me-1"></i>Registrar Paciente
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}