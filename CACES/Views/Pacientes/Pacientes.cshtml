@model List<CACES.DAL.Entidades.Paciente>

@{
    ViewData["Title"] = "Pacientes";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header banner-header p-4">
            <div class="d-flex justify-content-between align-items-center">

                <div>
                    <h3 class="mb-1 fw-bold">
                        <i class="bi bi-person-badge-fill me-2"></i>Gestión de Pacientes
                    </h3>
                    <p class="mb-0 opacity-75">
                        Consulta, registro y desactivación de pacientes del sistema.
                    </p>
                </div>

                <a asp-action="RegistrarPaciente"
                   asp-controller="Paciente"
                   class="btn btn-light fw-semibold">
                    + Registrar Paciente
                </a>

            </div>
        </div>

        <div class="card-body p-4">

            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success rounded-3">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Mensaje"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                </div>
            }

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">

                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>DUI</th>
                                <th>Correo</th>
                                <th>Teléfono</th>
                                <th>Dirección</th>
                                <th>Estado</th>
                                <th style="width:220px;">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var paciente in Model)
                            {
                                <tr>
                                    <td>
                                        @paciente.Usuario.Nombres
                                        @paciente.Usuario.PrimerApellido
                                        @paciente.Usuario.SegundoApellido
                                    </td>

                                    <td>@paciente.Usuario.DUI</td>

                                    <td>@paciente.Usuario.CorreoElectronico</td>

                                    <td>@paciente.Usuario.Telefono</td>

                                    <td>@paciente.Usuario.Direccion</td>

                                    <td>
                                        @if (paciente.Usuario.Estado == 1)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Desactivado</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="d-flex gap-2">

                                            <a asp-controller="Paciente"
                                               asp-action="DetallePaciente"
                                               asp-route-id="@paciente.IdPaciente"
                                               class="btn btn-info btn-sm text-white"
                                               title="Ver detalle">
                                                <i class="bi bi-eye-fill"></i>
                                            </a>

                                            <a asp-controller="Perfil"
                                               asp-action="ActualizarPerfil"
                                               asp-route-id="@paciente.IdPaciente"
                                               class="btn btn-warning btn-sm text-white"
                                               title="Editar paciente">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            @if (paciente.Usuario.Estado == 1)
                                            {
                                                <form asp-controller="Paciente"
                                                      asp-action="DesactivarPaciente"
                                                      method="post"
                                                      class="d-inline">

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@paciente.IdPaciente" />

                                                    <button type="submit"
                                                            class="btn btn-danger btn-sm"
                                                            title="Desactivar paciente"
                                                            onclick="return confirm('¿Desea desactivar este paciente?');">
                                                        <i class="bi bi-person-x-fill"></i>
                                                    </button>

                                                </form>
                                            }

                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info rounded-3">
                    No hay pacientes registrados.
                </div>
            }

        </div>
    </div>
</div>