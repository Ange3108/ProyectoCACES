@model List<CACES.DAL.Entidades.Paciente>

@{
    ViewData["Title"] = "Pacientes";
}

<section class="container py-5">

    <div class="top-action">
        <a class="btn btn-add"
           asp-controller="Paciente"
           asp-action="RegistroPaciente">
            + Registrar Paciente
        </a>
    </div>

    <section class="mt-4">

        <div class="card shadow-sm border-0">
            <div class="card-body">

                <h4 class="card-title mb-1">Listado de Pacientes</h4>
                <p class="text-muted mb-3">
                    Gestión de pacientes del sistema
                </p>

                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Mensaje"]
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["Error"]
                    </div>
                }

                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Correo Electrónico</th>
                                <th>DUI</th>
                                <th>Teléfono</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (Model != null && Model.Any())
                            {
                                foreach (var paciente in Model)
                                {
                                    <tr>
                                        <td>
                                            @paciente.Usuario.Nombres
                                            @paciente.Usuario.PrimerApellido
                                            @paciente.Usuario.SegundoApellido
                                        </td>

                                        <td>
                                            @paciente.Usuario.CorreoElectronico
                                        </td>

                                        <td>
                                            @paciente.Usuario.DUI
                                        </td>

                                        <td>
                                            @paciente.Usuario.Telefono
                                        </td>

                                        <td>

                                            <a asp-controller="Paciente"
                                               asp-action="DetallePaciente"
                                               asp-route-id="@paciente.IdPaciente"
                                               class="btn btn-sm btn-info">
                                                Ver detalle
                                            </a>

                                            <form asp-controller="Paciente"
                                                  asp-action="DesactivarPaciente"
                                                  method="post"
                                                  style="display:inline;">

                                                <input type="hidden"
                                                       name="id"
                                                       value="@paciente.IdPaciente" />

                                                <button type="submit"
                                                        class="btn btn-sm btn-danger"
                                                        onclick="return confirm('¿Desea desactivar este paciente?');">
                                                    Desactivar
                                                </button>

                                            </form>

                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center">
                                        No hay pacientes registrados.
                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>
        </div>

    </section>

</section>