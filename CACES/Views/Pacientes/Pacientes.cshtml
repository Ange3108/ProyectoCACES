@model List<CACES.DAL.Entidades.Paciente>

@{
    ViewData["Title"] = "Pacientes";
}

<section class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary mb-1">Gestión de Pacientes</h1>
            <p class="text-muted mb-0">Consulta, registro y desactivación de pacientes del sistema.</p>
        </div>

        <a class="btn btn-primary px-4 rounded-3"
           asp-controller="Paciente"
           asp-action="RegistroPaciente">
            <i class="bi bi-person-plus-fill me-1"></i>
            Registrar Paciente
        </a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success rounded-3">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Mensaje"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header text-white p-4"
             style="background: linear-gradient(135deg, #1f3c88, #4fc3f7);">
            <h4 class="mb-1 fw-bold">
                <i class="bi bi-people-fill me-2"></i>
                Listado de Pacientes
            </h4>
            <p class="mb-0 opacity-75">
                Información de contacto y estado de los pacientes registrados.
            </p>
        </div>

        <div class="card-body p-4">

            @if (Model != null && Model.Any())
            {
                <div class="row g-4">
                    @foreach (var paciente in Model)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm rounded-4">

                                <div class="card-body p-4">

                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3"
                                             style="width:50px;height:50px;">
                                            <i class="bi bi-person-fill fs-4"></i>
                                        </div>

                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                @paciente.Usuario.Nombres
                                                @paciente.Usuario.PrimerApellido
                                            </h5>

                                            <small class="text-muted">
                                                DUI: @paciente.Usuario.DUI
                                            </small>
                                        </div>
                                    </div>

                                    <p class="mb-2">
                                        <i class="bi bi-envelope-fill text-primary me-2"></i>
                                        <strong>Correo:</strong>
                                        @paciente.Usuario.CorreoElectronico
                                    </p>

                                    <p class="mb-2">
                                        <i class="bi bi-telephone-fill text-primary me-2"></i>
                                        <strong>Teléfono:</strong>
                                        @paciente.Usuario.Telefono
                                    </p>

                                    <p class="mb-3">
                                        <i class="bi bi-geo-alt-fill text-primary me-2"></i>
                                        <strong>Dirección:</strong>
                                        @paciente.Usuario.Direccion
                                    </p>

                                    <div class="mb-3">
                                        @if (paciente.Usuario.Estado == 1)
                                        {
                                            <span class="badge bg-success rounded-pill px-3 py-2">
                                                Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill px-3 py-2">
                                                Desactivado
                                            </span>
                                        }
                                    </div>

                                    <div class="d-flex gap-2">

                                        <a asp-controller="Paciente"
                                           asp-action="DetallePaciente"
                                           asp-route-id="@paciente.IdPaciente"
                                           class="btn btn-info btn-sm text-white rounded-3">
                                            <i class="bi bi-eye-fill me-1"></i>
                                            Ver detalle
                                        </a>

                                        @if (paciente.Usuario.Estado == 1)
                                        {
                                            <form asp-controller="Paciente"
                                                  asp-action="DesactivarPaciente"
                                                  method="post"
                                                  class="d-inline">

                                                <input type="hidden"
                                                       name="id"
                                                       value="@paciente.IdPaciente" />

                                                <button type="submit"
                                                        class="btn btn-danger btn-sm rounded-3"
                                                        onclick="return confirm('¿Desea desactivar este paciente?');">
                                                    <i class="bi bi-person-x-fill me-1"></i>
                                                    Desactivar
                                                </button>

                                            </form>
                                        }

                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info text-center rounded-3 mb-0">
                    No hay pacientes registrados.
                </div>
            }

        </div>
    </div>

</section>