@model CACES.BLL.DTOs.HorariosDisponibles.AsignarHorario

<div class="container mt-4">
    <h2>Configuración Dinámica de Horarios</h2>
    <hr />

    <form asp-action="Registrar" method="post">

        <div class="form-group mb-4">
            <label class="control-label font-weight-bold">Seleccione el Médico:</label>
            <select name="Formulario.IdMedico" class="form-control" asp-items='(SelectList)ViewData["MedicosSelectList"]'>
                <option value="">-- Seleccione un Médico --</option>
            </select>
            <span asp-validation-for="Formulario.IdMedico" class="text-danger"></span>
        </div>

        <h4>Bloques de Horarios Disponibles</h4>
        <br />

        <div class="row mb-3">
            <div class="col-md-4">
                <label class="font-weight-bold">Día de la Semana</label>
                <select name="Formulario.Horarios[0].DiaSemana" class="form-control">
                    <option value="0">Lunes</option>
                    <option value="1">Martes</option>
                    <option value="2">Miércoles</option>
                    <option value="3">Jueves</option>
                    <option value="4">Viernes</option>
                    <option value="5">Sábado</option>
                    <option value="6">Domingo</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="font-weight-bold">Hora Inicio</label>
                <input type="time" name="Formulario.Horarios[0].HoraInicio" class="form-control"
                       value="@Model.Formulario?.Horarios?.ElementAtOrDefault(0)?.HoraInicio" />
            </div>
            <div class="col-md-4">
                <label class="font-weight-bold">Hora Fin</label>
                <input type="time" name="Formulario.Horarios[0].HoraFin" class="form-control"
                       value="@Model.Formulario?.Horarios?.ElementAtOrDefault(0)?.HoraFin" />
            </div>
        </div>

        <button type="submit" class="btn btn-success mt-3">Guardar Configuración</button>
    </form>
</div>
